# Copiá este archivo como .env y completá los valores reales.
# El archivo .env está en .gitignore y NUNCA se sube a GitHub.

# Token Permanente de Meta (WhatsApp Business API)
META_TOKEN=PEGAR_TOKEN_PERMANENTE_AQUI

# Identificador del número de teléfono de WhatsApp Business (Phone Number ID)
META_PHONE_ID=PEGAR_PHONE_NUMBER_ID_AQUI

# Identificador de la cuenta de WhatsApp Business (WABA ID)
META_WABA_ID=PEGAR_WABA_ID_AQUI

# Número de WhatsApp del admin que recibe notificaciones de nueva reserva
# Formato internacional sin + (ej: 5493757XXXXXX)
ADMIN_PHONE=PEGAR_NUMERO_ADMIN_AQUI

# Nombre del admin para la plantilla nueva_reserva ({{1}})
ADMIN_NAME=PEGAR_NOMBRE_ADMIN_AQUI

# Puerto del servidor (3000 por defecto)
PORT=3000

# Firebase Admin SDK — proyecto dridanna-e4ee2
# Descargar service account en: Firebase Console → Configuración → Cuentas de servicio → Generar nueva clave privada
FIREBASE_PROJECT_ID=dridanna-e4ee2
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@dridanna-e4ee2.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...clave privada...\n-----END PRIVATE KEY-----\n"
